{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewerOutput",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["approved", "rejected"]
    },
    "summary": {
      "type": "string"
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      }
    },
    "requested_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      }
    },
    "non_blocking_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "message": {
            "type": "string"
          }
        },
        "required": ["message"]
      }
    }
  },
  "required": [
    "status",
    "summary",
    "blocking_issues",
    "requested_changes",
    "non_blocking_issues"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "approved"
          }
        }
      },
      "then": {
        "properties": {
          "blocking_issues": {
            "maxItems": 0
          },
          "requested_changes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "rejected"
          }
        }
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "blocking_issues": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "requested_changes": {
                "minItems": 1
              }
            }
          }
        ]
      }
    }
  ]
}
