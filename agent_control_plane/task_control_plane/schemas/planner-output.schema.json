{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlannerOutput",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "status": {
      "type": "string",
      "enum": ["planned", "needs_answers"]
    },
    "plan_markdown": {
      "type": "string"
    },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "context": {
            "type": "string"
          },
          "question": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        },
        "required": ["id", "question"]
      }
    }
  },
  "required": ["status"],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "planned"
          }
        }
      },
      "then": {
        "required": ["plan_markdown"]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "needs_answers"
          }
        }
      },
      "then": {
        "required": ["questions"]
      }
    }
  ]
}
